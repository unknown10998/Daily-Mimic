{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "daily-mimic",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create Mimic",
        "description": "Mimic",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "daily_mimic_dev"
  },
  "settings": {
    "global": {
      "GOOGLE_GEMINI_API_KEY": {
        "type": "string",
        "label": "Google Gemini API key",
        "helpText": "Secret API key used by the Reddit-hosted server for Gemini moderation, generation, and daily question evolution.",
        "isSecret": true
      },
      "GOOGLE_GEMINI_MODEL": {
        "type": "string",
        "label": "Google Gemini model",
        "helpText": "Gemini model used by Mimic. gemini-2.5-flash is verified for this app.",
        "defaultValue": "gemini-2.5-flash"
      }
    }
  }
}
